-- ================= SELECT =================

-- 1) Select film ordered by year
SELECT film_id, title, release_year
FROM film
ORDER BY release_year;

-- 2) Filter subscription plans with price less than or equal to 9.99
SELECT subscription_id, type, price
FROM subscription
WHERE price <= 9.99
ORDER BY price;

-- 3) Select completed payments ordered by payment date
SELECT *
FROM payment
WHERE status = TRUE
ORDER BY payment_date DESC;

-- 4) Select films of certain Actor("Tom Holland")
SELECT f.title, f.release_year, f.duration, a.first_name, a.last_name
FROM film AS f
JOIN film_actor AS fa ON f.film_id = fa.film_id
JOIN actor AS a ON fa.actor_id = a.actor_id
WHERE a.first_name = 'Tom' 
  AND a.last_name = 'Holland'
ORDER BY f.release_year ASC;

-- 5) Select films of certain director("Greta Gerwig")
SELECT f.title, f.release_year, f.duration, d.first_name, d.last_name
FROM film AS f
JOIN film_director AS fd ON f.film_id = fd.film_id
JOIN director AS d ON fd.director_id = d.director_id
WHERE d.first_name = 'Greta' 
  AND d.last_name = 'Gerwig'
ORDER BY f.release_year ASC;

-- 6) Select normal films (16+)
SELECT title, release_year, age_restriction
FROM film
WHERE age_restriction IN ('16+', '18+', '21+')
ORDER BY release_year ASC;

-- 7) Select top 10 newest films of our service
SELECT title, release_year, duration, age_restriction
FROM film
ORDER BY release_year DESC
LIMIT 10;
 
